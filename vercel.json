{
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "routes": [
        {
            "src": "/citas",
            "dest": "/citas.html"
        },
        {
            "src": "/blog",
            "dest": "/blog.html"
        },
        {
            "src": "/faq",
            "dest": "/faq.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}