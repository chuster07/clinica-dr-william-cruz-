# ============================================================================
# 🏥 CONFIGURACIÓN N8N - CLÍNICA DR. WILLIAM CRUZ
# ============================================================================
# 
# 📋 INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. NUNCA subas .env a Git (ya está en .gitignore)
# 4. Guarda una copia segura de .env como respaldo
#
# ============================================================================

# ============================================================================
# 🚀 N8N - CONFIGURACIÓN PRINCIPAL
# ============================================================================

# Credenciales de acceso a n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambiar_por_password_seguro_123

# URL y puerto de n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Configuraciones adicionales de n8n
N8N_ENCRYPTION_KEY=cambiar_por_clave_segura_32_caracteres
N8N_CORS_ALLOW_ORIGINS=*

# Timezone (importante para citas y recordatorios)
TZ=America/Costa_Rica
GENERIC_TIMEZONE=America/Costa_Rica

# Logs y debugging
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console

# ============================================================================
# 📧 GMAIL - ENVÍO DE EMAILS
# ============================================================================
# 
# 📝 CÓMO OBTENER:
# 1. Activar 2FA: https://myaccount.google.com/security
# 2. Generar App Password: https://myaccount.google.com/apppasswords
# 3. Copiar los 16 caracteres (sin espacios)
#
# ============================================================================

GMAIL_EMAIL=tucorreo@gmail.com
GMAIL_APP_PASSWORD=abcd-efgh-ijkl-mnop

# Configuración SMTP (alternativa)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=${GMAIL_EMAIL}
SMTP_PASSWORD=${GMAIL_APP_PASSWORD}

# ============================================================================
# 📊 GOOGLE SHEETS & CALENDAR - ALMACENAMIENTO DE DATOS
# ============================================================================
#
# 📝 CÓMO OBTENER:
# 1. Crear proyecto: https://console.cloud.google.com
# 2. Habilitar APIs: Google Sheets API + Google Calendar API
# 3. Crear credenciales OAuth2
# 4. Copiar Client ID y Client Secret
# 5. Crear hoja "Clinica DB" con pestañas: Citas, Contactos, Pacientes
# 6. Copiar ID de la URL de Google Sheets
#
# ============================================================================

# OAuth2 credentials
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abcdefghijklmnop123456
GOOGLE_REDIRECT_URI=http://localhost:5678/rest/oauth2-credential/callback

# Google Sheets Database
GOOGLE_SHEET_ID=1ABC123xyz456DEF789ghi012JKL345mno
GOOGLE_SHEET_CITAS=Citas
GOOGLE_SHEET_CONTACTOS=Contactos
GOOGLE_SHEET_PACIENTES=Pacientes

# Google Calendar
GOOGLE_CALENDAR_ID=primary

# ============================================================================
# 📱 TELEGRAM - NOTIFICACIONES INTERNAS
# ============================================================================
#
# 📝 CÓMO OBTENER:
# 1. Hablar con @BotFather en Telegram
# 2. Enviar: /newbot
# 3. Seguir instrucciones
# 4. Copiar token del bot
# 5. Para Chat ID: hablar con @userinfobot
#
# ============================================================================

TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ADMIN_CHAT_ID=123456789

# Canal de notificaciones (opcional)
TELEGRAM_CHANNEL_ID=@nombre_del_canal

# ============================================================================
# 📲 WHATSAPP - MENSAJES A PACIENTES
# ============================================================================
#
# 📝 OPCIONES:
# 
# OPCIÓN A - Evolution API (GRATIS, self-hosted):
#   - Ya incluido en docker-compose.yml
#   - Acceder: http://localhost:8080
#   - Escanear QR con WhatsApp Business
#
# OPCIÓN B - WhatsApp Cloud API (GRATIS hasta 1000 msg/mes):
#   - Crear app: https://developers.facebook.com
#   - Obtener Phone Number ID y Access Token
#
# ============================================================================

# Evolution API (Opción A - Recomendado)
EVOLUTION_API_KEY=ClinicaDrWilliamCruz_2026_CambiarEsto
EVOLUTION_SERVER_URL=http://evolution-api:8080
EVOLUTION_INSTANCE_NAME=clinica-whatsapp

# WhatsApp Cloud API (Opción B)
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAABsbCS1iHgBO...
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu-token-de-verificacion-seguro

# Número de WhatsApp de la clínica
WHATSAPP_CLINIC_NUMBER=+50688888888

# ============================================================================
# 🤖 OPENAI - CHATBOT CON IA (OPCIONAL)
# ============================================================================
#
# 📝 CÓMO OBTENER:
# 1. Crear cuenta: https://platform.openai.com
# 2. Ir a: https://platform.openai.com/api-keys
# 3. Crear nueva API Key
# 4. Copiar (empieza con sk-)
#
# 💰 COSTO: ~$5-10/mes con uso moderado
# 💡 TIP: Empieza con gpt-3.5-turbo (más barato)
#
# ============================================================================

OPENAI_API_KEY=sk-proj-abcdefghijklmnopqrstuvwxyz123456
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# Alternativas (GRATIS):
# - Groq: https://console.groq.com
# - Ollama: http://localhost:11434 (local)
GROQ_API_KEY=gsk_abcdefghijklmnopqrstuvwxyz
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# 🗄️ BASE DE DATOS (OPCIONAL - Para producción)
# ============================================================================
#
# 📝 NOTA: Por defecto n8n usa SQLite
# Para producción recomendamos PostgreSQL
#
# ============================================================================

# PostgreSQL
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_clinica
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=cambiar_por_password_seguro

# ============================================================================
# 🔐 SEGURIDAD Y AUTENTICACIÓN
# ============================================================================

# JWT para API authentication
JWT_SECRET=cambiar_por_secret_muy_seguro_min_32_caracteres

# Encriptación de credenciales
N8N_ENCRYPTION_KEY=cambiar_por_clave_encriptacion_32_chars

# CORS (permitir acceso desde tu dominio)
N8N_CORS_ALLOW_ORIGINS=http://localhost:3000,https://tudominio.com

# ============================================================================
# 🌐 CONFIGURACIÓN DE DOMINIO (PRODUCCIÓN)
# ============================================================================
#
# 📝 CUANDO TENGAS DOMINIO:
# 1. Cambiar WEBHOOK_URL a tu dominio
# 2. Configurar SSL/HTTPS
# 3. Actualizar GOOGLE_REDIRECT_URI
#
# ============================================================================

# Dominio público (cambiar en producción)
# WEBHOOK_URL=https://n8n.clinicadrwilliamcruz.com
# N8N_PROTOCOL=https
# GOOGLE_REDIRECT_URI=https://n8n.clinicadrwilliamcruz.com/rest/oauth2-credential/callback

# SSL/TLS
# N8N_SSL_KEY=/certs/privkey.pem
# N8N_SSL_CERT=/certs/fullchain.pem

# ============================================================================
# 📊 CONFIGURACIÓN CLÍNICA
# ============================================================================

# Información de la clínica
CLINIC_NAME=Clínica Dr. William Cruz
CLINIC_PHONE=+506-8888-8888
CLINIC_EMAIL=info@clinicadrwilliamcruz.com
CLINIC_ADDRESS=San José, Costa Rica
CLINIC_WEBSITE=https://clinicadrwilliamcruz.com

# Horarios de atención
CLINIC_HOURS_WEEKDAY=08:00-17:00
CLINIC_HOURS_SATURDAY=08:00-12:00

# Duraciones de citas (minutos)
APPOINTMENT_DURATION=30
REMINDER_BEFORE_HOURS=24

# ============================================================================
# 🧪 MODO DESARROLLO / DEBUG
# ============================================================================

# Activar logs detallados
DEBUG=true
NODE_ENV=development

# Para producción cambiar a:
# DEBUG=false
# NODE_ENV=production

# ============================================================================
# ✅ CHECKLIST DE CONFIGURACIÓN
# ============================================================================
#
# Antes de activar workflows, asegúrate de tener:
#
# [ ] N8N_BASIC_AUTH_PASSWORD cambiado
# [ ] GMAIL_EMAIL y GMAIL_APP_PASSWORD configurados
# [ ] GOOGLE_CLIENT_ID y GOOGLE_CLIENT_SECRET configurados
# [ ] GOOGLE_SHEET_ID de tu hoja "Clinica DB"
# [ ] TELEGRAM_BOT_TOKEN de @BotFather
# [ ] TELEGRAM_CHAT_ID de @userinfobot
# [ ] EVOLUTION_API_KEY cambiado (o WhatsApp Cloud API)
# [ ] OPENAI_API_KEY configurado (si usarás chatbot con IA)
# [ ] Todas las contraseñas cambiadas de los valores de ejemplo
#
# ============================================================================
#
# 🆘 AYUDA:
# - Documentación completa: Ver CONFIGURACION_COMPLETA.md
# - Inicio rápido: Ver INICIO_RAPIDO.md
# - Verificación: Ver CHECKLIST.md
# - Guía visual: Ver GUIA_VISUAL.md
#
# ============================================================================
#
# ⚠️ IMPORTANTE:
# - Este archivo (.env) NO debe subirse a Git
# - Ya está incluido en .gitignore
# - Guarda una copia segura como respaldo
# - Cambia TODAS las contraseñas por valores seguros
#
# ============================================================================
